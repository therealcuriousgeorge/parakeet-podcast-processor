feeds:
  - name: "Sharp Tech"
    url: "https://sharptech.fm/feed/podcast/YOUR_TOKEN_HERE"
    category: "tech"

  - name: "Lenny's Podcast"
    url: "https://api.substack.com/feed/podcast/10845/private/YOUR_TOKEN_HERE.rss"
    category: "product"

  # Add as many feeds as you want — one block per podcast.
  # The `name` field drives prompt routing:
  #   "Sharp Tech" or "Stratechery" → PROMPT_BEN_THOMPSON (extra: bens_takes, debates, analogies)
  #   "Lenny's Podcast"             → PROMPT_LENNY        (extra: guest_profile, career_playbooks)
  #   anything else                 → PROMPT_GENERIC
  #
  # - name: "Hard Fork"
  #   url: "https://..."
  #   category: "tech"
  #
  # - name: "No Priors"
  #   url: "https://..."
  #   category: "ai"
  #
  # - name: "Acquired"
  #   url: "https://..."
  #   category: "strategy"

settings:
  audio_format: "wav"           # wav or mp3
  max_episodes_per_feed: 3      # how many recent episodes to fetch per feed

  # Delete audio from data/audio/ after successful transcription.
  # A 1-hour WAV at 16kHz mono is ~115 MB — recommended: true
  cleanup_old_files: true

  # ── Transcription (audio → text) ─────────────────────────────────────────
  # Options:
  #   local-parakeet  Apple Silicon only · fastest · fully offline
  #   local-whisper   Any machine · fully offline · slower
  #   openai-api      Cloud · ~$0.006/min · requires OPENAI_API_KEY
  transcription_provider: "local-parakeet"

  # Parakeet MLX — used when transcription_provider is "local-parakeet"
  parakeet_enabled: true
  parakeet_model: "mlx-community/parakeet-tdt-0.6b-v2"
  # Split long episodes into chunks so each fits in Metal GPU memory.
  # 600s (10 min) uses ~2 GB per chunk — safe for a 16 GB M-series Mac.
  # Lower if you see OOM errors; raise on machines with more unified memory.
  parakeet_chunk_duration: 600

  # Whisper — used when transcription_provider is "local-whisper" (or as fallback)
  # Sizes: tiny, base, small, medium, large  (larger = more accurate, slower)
  whisper_model: "base"

  # ── LLM Provider (transcript → structured summary) ───────────────────────
  # Options:
  #   ollama     Fully local · free · requires `ollama serve` + model pulled
  #   openai     GPT-4o-mini / GPT-4o · requires OPENAI_API_KEY
  #   anthropic  Claude Haiku / Sonnet · requires ANTHROPIC_API_KEY
  #   gemini     Gemini Flash / Pro · requires GEMINI_API_KEY
  #
  # Recommendation: GPT-4o-mini or Claude Haiku for best quality/cost on
  # podcast summaries. Ollama (gemma3:12b) works but gives shallower results.
  llm_provider: "ollama"

  # Model name for your chosen provider:
  #   ollama:    gemma3:12b, llama3.2, mistral
  #   openai:    gpt-4o-mini, gpt-4o
  #   anthropic: claude-3-5-haiku-20241022, claude-3-7-sonnet-20250219
  #   gemini:    gemini-2.0-flash, gemini-1.5-pro
  llm_model: "gemma3:12b"

  # Ollama server URL (only used when llm_provider is "ollama")
  ollama_base_url: "http://localhost:11434"

  # ── Output ────────────────────────────────────────────────────────────────
  export_format:
    - "markdown"   # one .md file per episode: YYYY-MM-DD_PodcastName_EpisodeTitle.md
    - "json"       # combined digest JSON for the day
  email_enabled: false
